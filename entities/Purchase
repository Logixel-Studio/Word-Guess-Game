{
  "name": "Purchase",
  "type": "object",
  "properties": {
    "supplier_id": {
      "type": "string",
      "description": "Reference to supplier"
    },
    "supplier_name": {
      "type": "string",
      "description": "Supplier display name"
    },
    "purchase_type_id": {
      "type": "string",
      "description": "Reference to purchase type"
    },
    "purchase_type_name": {
      "type": "string",
      "description": "Purchase type display name"
    },
    "qty": {
      "type": "number",
      "description": "Quantity"
    },
    "unit_price": {
      "type": "number",
      "description": "Price per unit"
    },
    "total": {
      "type": "number",
      "description": "Auto-calculated total"
    },
    "description": {
      "type": "string",
      "description": "Notes"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "unpaid",
        "partial"
      ],
      "default": "unpaid"
    },
    "paid_amount": {
      "type": "number",
      "default": 0,
      "description": "Amount paid so far"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Payment due date"
    }
  },
  "required": [
    "supplier_id",
    "purchase_type_id",
    "qty",
    "unit_price"
  ]
}