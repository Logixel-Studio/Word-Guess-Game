{
  "name": "Expense",
  "type": "object",
  "properties": {
    "expense_type_id": {
      "type": "string",
      "description": "Reference to expense type"
    },
    "expense_type_name": {
      "type": "string",
      "description": "Expense type display name"
    },
    "qty": {
      "type": "number",
      "description": "Quantity"
    },
    "unit_price": {
      "type": "number",
      "description": "Price per unit"
    },
    "total": {
      "type": "number",
      "description": "Auto-calculated total"
    },
    "description": {
      "type": "string",
      "description": "Notes"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "unpaid",
        "partial"
      ],
      "default": "unpaid"
    },
    "paid_amount": {
      "type": "number",
      "default": 0,
      "description": "Amount paid so far"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Payment due date"
    },
    "created_by_id": {
      "type": "string"
    },
    "created_by_name": {
      "type": "string"
    },
    "created_by_email": {
      "type": "string"
    },
    "created_by_role": {
      "type": "string"
    },
    "updated_by_id": {
      "type": "string"
    },
    "updated_by_name": {
      "type": "string"
    },
    "updated_by_email": {
      "type": "string"
    },
    "updated_by_role": {
      "type": "string"
    }
  },
  "required": [
    "expense_type_id",
    "qty",
    "unit_price"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    }
  }
}