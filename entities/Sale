{
  "name": "Sale",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "Reference to client"
    },
    "client_name": {
      "type": "string",
      "description": "Client display name"
    },
    "product_id": {
      "type": "string",
      "description": "Reference to product"
    },
    "product_name": {
      "type": "string",
      "description": "Product display name"
    },
    "qty": {
      "type": "number",
      "description": "Quantity sold"
    },
    "unit_price": {
      "type": "number",
      "description": "Selling price per unit"
    },
    "total": {
      "type": "number",
      "description": "Auto-calculated total"
    },
    "cost_per_unit": {
      "type": "number",
      "description": "Production cost per unit"
    },
    "profit": {
      "type": "number",
      "description": "Profit from this sale"
    },
    "description": {
      "type": "string",
      "description": "Notes"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "unpaid",
        "partial"
      ],
      "default": "unpaid"
    },
    "paid_amount": {
      "type": "number",
      "default": 0,
      "description": "Amount paid so far"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Payment due date"
    },
    "created_by_id": {
      "type": "string"
    },
    "created_by_name": {
      "type": "string"
    },
    "created_by_email": {
      "type": "string"
    },
    "created_by_role": {
      "type": "string"
    },
    "updated_by_id": {
      "type": "string"
    },
    "updated_by_name": {
      "type": "string"
    },
    "updated_by_email": {
      "type": "string"
    },
    "updated_by_role": {
      "type": "string"
    }
  },
  "required": [
    "client_id",
    "product_id",
    "qty",
    "unit_price"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "sales_manager"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "sales_manager"
          }
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "manager"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "sales_manager"
          }
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "sales_manager"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    }
  }
}