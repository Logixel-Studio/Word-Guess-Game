{
  "name": "CustomRole",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique role key (snake_case)"
    },
    "label": {
      "type": "string",
      "description": "Human-readable label"
    },
    "description": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "default": "text-slate-400"
    },
    "is_system": {
      "type": "boolean",
      "default": false,
      "description": "True for built-in roles"
    },
    "is_archived": {
      "type": "boolean",
      "default": false
    },
    "based_on": {
      "type": "string",
      "description": "Original role key if duplicated"
    }
  },
  "required": [
    "key",
    "label"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "super_admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "super_admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "super_admin"
      }
    }
  }
}